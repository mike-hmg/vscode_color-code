{
	"name": "colorcode",
	"displayName": "ColorCode",
	"description": "Customize colors for files and folders in your workspace",
	"publisher": "ColorCode",
	"version": "1.1.3",
	"license": "MIT",
	"icon": "resources/images/icon.jpg",
	"repository": "https://github.com/mike-hmg/vscode_color-code.git",
	"engines": {
		"vscode": "^1.92.0"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"file",
		"folder",
		"color",
		"customization"
	],
	"pricing": "Free",
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"configuration": {
			"title": "ColorCode",
			"properties": {
				"colorcode.items": {
					"type": "array",
					"title": "Colorized Items",
					"items": {
						"type": "object",
						"properties": {
							"path": {
								"type": "string",
								"description": "Path to the file or folder"
							},
							"color": {
								"type": "string",
								"description": "Color for the item (e.g., #ff0000 or colormanagement.AnsiColor1)"
							}
						},
						"required": [
							"path",
							"color"
						]
					},
					"default": []
				}
			}
		},
		"menus": {
			"explorer/context": [
				{
					"when": "resourceFilename",
					"command": "colorcode.setFileColor",
					"group": "1_modification@1"
				},
				{
					"when": "resourceFilename",
					"command": "colorcode.clearFileColor",
					"group": "1_modification@2"
				},
				{
					"when": "explorerResourceIsFolder",
					"command": "colorcode.setFolderColor",
					"group": "navigation@1"
				},
				{
					"when": "explorerResourceIsFolder",
					"command": "colorcode.clearFolderColor",
					"group": "navigation@2"
				}
			]
		},
		"commands": [
			{
				"command": "colorcode.setFileColor",
				"title": "Set File Color",
				"category": "ColorCode"
			},
			{
				"command": "colorcode.clearFileColor",
				"title": "Clear File Color",
				"category": "ColorCode"
			},
			{
				"command": "colorcode.setFolderColor",
				"title": "Set Folder Color",
				"category": "ColorCode"
			},
			{
				"command": "colorcode.clearFolderColor",
				"title": "Clear Folder Color",
				"category": "ColorCode"
			}
		],
		"colors": [
			{
				"id": "colormanagement.AnsiColor1",
				"defaults": {
