	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1"
	},
	"author": "",
	"type": "commonjs",
	"devDependencies": {
		"@types/vscode": "^1.92.0",
		"esbuild": "^0.27.3",
		"typescript": "^5.9.3"
	}
}
